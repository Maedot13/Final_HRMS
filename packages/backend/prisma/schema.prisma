generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Multi-campus support (Phase 1)
// ---------------------------------------------------------------------------

model Campus {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  timezone    String?  @default("Africa/Addis_Ababa")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employeeIdPrefix        String   @default("EMP")
  employeeNumericLength   Int      @default(4)
  employeeSequenceCurrent Int      @default(0)
  isPatternLocked         Boolean  @default(false)

  users                 User[]
  employees              Employee[]
  leaveRequests         LeaveRequest[]
  leaveBalances         LeaveBalance[]
  sabbaticalRequests    SabbaticalRequest[]
  clearanceRequests     ClearanceRequest[]
  clearanceUnits        ClearanceUnit[]
  jobPostings           JobPosting[]
  notifications         Notification[]
  auditLogs             AuditLog[]
  departments           Department[]
}

enum UserScope {
  CAMPUS
  UNIVERSITY
}

model User {
  id            Int            @id @default(autoincrement())
  passwordHash  String
  role          UserRole
  scope         UserScope      @default(CAMPUS)
  campusId      Int?
  employeeId    String         @unique
  email         String         @unique
  mustChangePassword Boolean   @default(false)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  campus        Campus?        @relation(fields: [campusId], references: [id], onDelete: Restrict)
  employee      Employee?
  jobPostings   JobPosting[]   @relation("JobCreator")
  notifications Notification[]
  refreshTokens RefreshToken[]

  @@index([campusId])
}

model Employee {
  id         Int      @id @default(autoincrement())
  campusId   Int?
  userId     Int      @unique
  employeeId String   @unique
  name       String
  deptLegacy         String              @map("department") // transition legacy field
  departmentId       Int?
  position           String
  hireDate           DateTime

  serviceYears       Int                 @default(0)
  grossSalary        Float               @default(0)
  salaryType         SalaryType          @default(MONTHLY)
  contactInfo        Json
  campus             Campus?             @relation(fields: [campusId], references: [id], onDelete: Restrict)
  clearanceRequests  ClearanceRequest[]
  department         Department?         @relation(fields: [departmentId], references: [id])
  headOf             Department?         @relation("DeptHead")
  user               User                @relation(fields: [userId], references: [id])
  jobApplications    JobApplication[]
  leaveBalances      LeaveBalance[]
  leaveRequests      LeaveRequest[]
  payrollTransfers   PayrollTransfer[]
  sabbaticalRequests SabbaticalRequest[]

  @@index([campusId])
}

model LeaveRequest {
  id              Int         @id @default(autoincrement())
  campusId        Int?
  employeeId      Int
  leaveType       LeaveType
  startDate       DateTime
  endDate         DateTime
  days            Int
  reason          String
  attachmentUrl   String?
  status          LeaveStatus @default(PENDING)
  approverId      Int?
  approverComment String?
  resolvedAt      DateTime?
  lastDecisionAt  DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  campus          Campus?     @relation(fields: [campusId], references: [id], onDelete: Restrict)
  employee        Employee    @relation(fields: [employeeId], references: [id])

  @@index([campusId])
  @@index([employeeId, status])
  @@index([status, createdAt])
}

model LeaveBalance {
  id               Int      @id @default(autoincrement())
  campusId         Int?
  employeeId       Int
  year             Int
  annualBalance    Int      @default(0)
  sickBalance      Int      @default(0)
  maternityBalance Int      @default(0)
  paternityBalance Int      @default(0)
  campus           Campus?  @relation(fields: [campusId], references: [id], onDelete: Restrict)
  employee         Employee @relation(fields: [employeeId], references: [id])

  @@index([campusId])
  @@unique([employeeId, year])
}

model SabbaticalRequest {
  id              Int         @id @default(autoincrement())
  campusId        Int?
  employeeId      Int
  purpose         String
  startDate       DateTime
  endDate         DateTime
  durationMonths  Int
  plan            String
  planDocumentUrl String?
  status          LeaveStatus @default(PENDING)
  approverId      Int?
  approverComment String?
  resolvedAt      DateTime?
  lastDecisionAt  DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  campus          Campus?     @relation(fields: [campusId], references: [id], onDelete: Restrict)
  employee        Employee    @relation(fields: [employeeId], references: [id])

  @@index([campusId])
}

model ClearanceRequest {
  id             Int             @id @default(autoincrement())
  campusId       Int?
  employeeId     Int
  reason         String
  lastWorkingDay DateTime
  status         ClearanceStatus @default(PENDING)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  campus          Campus?         @relation(fields: [campusId], references: [id], onDelete: Restrict)
  checks          ClearanceCheck[]
  employee        Employee         @relation(fields: [employeeId], references: [id])
  payrollTransfer PayrollTransfer?

  @@index([campusId])
}

model ClearanceUnit {
  id                Int              @id @default(autoincrement())
  campusId          Int?
  name              String
  description       String?
  isActive          Boolean          @default(true)
  isSystemGenerated Boolean          @default(false)
  createdAt         DateTime         @default(now())
  campus            Campus?          @relation(fields: [campusId], references: [id], onDelete: Restrict)
  checks            ClearanceCheck[]

  @@unique([campusId, name])
  @@index([campusId])
}

model ClearanceCheck {
  id          Int              @id @default(autoincrement())
  clearanceId Int
  unitId      Int
  status      ClearanceStatus  @default(PENDING)
  approverId  Int?
  approvedAt  DateTime?
  comment     String?
  clearance   ClearanceRequest @relation(fields: [clearanceId], references: [id])
  unit        ClearanceUnit    @relation(fields: [unitId], references: [id])

  @@unique([clearanceId, unitId])
  @@index([unitId, status])
  @@index([clearanceId, status])
}

model PayrollTransfer {
  id            Int              @id @default(autoincrement())
  employeeId    Int
  clearanceId   Int              @unique
  reason        String
  effectiveDate DateTime
  status        String
  createdBy     Int
  createdAt     DateTime         @default(now())
  clearance     ClearanceRequest @relation(fields: [clearanceId], references: [id])
  employee      Employee         @relation(fields: [employeeId], references: [id])
}

model JobPosting {
  id           Int              @id @default(autoincrement())
  campusId     Int?
  title        String
  description  String
  requirements String
  deptLegacy    String           @map("department") // legacy
  position     String
  deadline     DateTime
  status       JobStatus        @default(OPEN)
  createdBy    Int
  createdAt    DateTime         @default(now())
  campus       Campus?          @relation(fields: [campusId], references: [id], onDelete: Restrict)
  applications JobApplication[]
  creator      User             @relation("JobCreator", fields: [createdBy], references: [id])

  @@index([campusId])
}

model JobApplication {
  id            Int               @id @default(autoincrement())
  jobPostingId  Int
  employeeId    Int
  coverLetter   String
  cvUrl         String
  status        ApplicationStatus @default(SUBMITTED)
  reviewedBy    Int?
  reviewComment String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  employee      Employee          @relation(fields: [employeeId], references: [id])
  jobPosting    JobPosting        @relation(fields: [jobPostingId], references: [id])

  @@unique([jobPostingId, employeeId])
}

model Notification {
  id          Int      @id @default(autoincrement())
  campusId    Int?
  userId      Int
  type        String
  title       String
  message     String
  relatedId   Int?
  relatedType String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  campus      Campus?  @relation(fields: [campusId], references: [id], onDelete: SetNull)
  user        User     @relation(fields: [userId], references: [id])

  @@index([campusId])
}

model RefreshToken {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  expiresAt  DateTime
  revoked    Boolean  @default(false)
  replacedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, revoked])
  @@index([expiresAt])
}

model AuditLog {
  id         Int         @id @default(autoincrement())
  campusId   Int?
  userId     Int?
  action     AuditAction
  entityType String
  entityId   Int?
  changes    Json?
  status     AuditStatus @default(SUCCESS)
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime    @default(now())

  campus     Campus?     @relation(fields: [campusId], references: [id], onDelete: SetNull)

  @@index([campusId, timestamp])
  @@index([userId, timestamp])
  @@index([action, timestamp])
  @@index([entityType, entityId])
}

model Department {
    id              Int       @id @default(autoincrement())
    campusId        Int
    name            String
    headEmployeeId  Int?      @unique    // enforces ONE head per dept at DB level
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @updatedAt

    campus          Campus    @relation(fields: [campusId], references: [id], onDelete: Restrict)
    head            Employee? @relation("DeptHead", fields: [headEmployeeId], references: [id])
    employees       Employee[]

    @@unique([campusId, name])     // dept name unique within a campus
    @@index([campusId])
}

enum AuditStatus {
  SUCCESS
  FAILURE
  DENIED
}

enum AuditAction {
  USER_LOGIN
  USER_LOGOUT
  USER_REGISTER
  LEAVE_REQUEST_CREATE
  LEAVE_REQUEST_APPROVE
  LEAVE_REQUEST_REJECT
  CLEARANCE_INITIATE
  CLEARANCE_APPROVE
  CLEARANCE_REJECT
  SABBATICAL_REQUEST_CREATE
  SABBATICAL_APPROVE
  SABBATICAL_REJECT
  EMPLOYEE_CREATE
  EMPLOYEE_UPDATE
  PAYROLL_TRANSFER_CREATE
  USER_ROLE_UPDATE
  USER_STATUS_TOGGLE
  AUDIT_LOG_ACCESSED
  AUDIT_LOG_EXPORTED
  CAMPUS_CREATED
  CAMPUS_ACTIVATED
  CAMPUS_SUSPENDED
  DEPARTMENT_CREATED
  DEPARTMENT_HEAD_CHANGED
}

enum UserRole {
  ADMIN
  HR_OFFICER
  DEPARTMENT_HEAD
  FINANCE_OFFICER
  RECRUITMENT_COMMITTEE
  EMPLOYEE
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ClearanceStatus {
  PENDING
  APPROVED
  REJECTED
}

enum JobStatus {
  OPEN
  CLOSED
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  REJECTED
}

enum SalaryType {
  MONTHLY
  DAILY
}
