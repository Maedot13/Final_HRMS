generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  passwordHash  String
  role          UserRole
  employeeId    String         @unique
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  employee      Employee?
  jobPostings   JobPosting[]   @relation("JobCreator")
  notifications Notification[]
  refreshTokens RefreshToken[]
}

model Employee {
  id                 Int                 @id @default(autoincrement())
  userId             Int                 @unique
  employeeId         String              @unique
  name               String
  department         String
  position           String
  hireDate           DateTime

  serviceYears       Int                 @default(0)
  grossSalary        Float               @default(0)
  salaryType         SalaryType          @default(MONTHLY)
  contactInfo        Json
  clearanceRequests  ClearanceRequest[]
  user               User                @relation(fields: [userId], references: [id])
  jobApplications    JobApplication[]
  leaveBalances      LeaveBalance[]
  leaveRequests      LeaveRequest[]
  payrollTransfers   PayrollTransfer[]
  sabbaticalRequests SabbaticalRequest[]
}

model LeaveRequest {
  id              Int         @id @default(autoincrement())
  employeeId      Int
  leaveType       LeaveType
  startDate       DateTime
  endDate         DateTime
  days            Int
  reason          String
  attachmentUrl   String?
  status          LeaveStatus @default(PENDING)
  approverId      Int?
  approverComment String?
  resolvedAt      DateTime?
  lastDecisionAt  DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  employee        Employee    @relation(fields: [employeeId], references: [id])
}

model LeaveBalance {
  id               Int      @id @default(autoincrement())
  employeeId       Int
  year             Int
  annualBalance    Int      @default(0)
  sickBalance      Int      @default(0)
  maternityBalance Int      @default(0)
  paternityBalance Int      @default(0)
  employee         Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, year])
}

model SabbaticalRequest {
  id              Int         @id @default(autoincrement())
  employeeId      Int
  purpose         String
  startDate       DateTime
  endDate         DateTime
  durationMonths  Int
  plan            String
  planDocumentUrl String?
  status          LeaveStatus @default(PENDING)
  approverId      Int?
  approverComment String?
  resolvedAt      DateTime?
  lastDecisionAt  DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  employee        Employee    @relation(fields: [employeeId], references: [id])
}

model ClearanceRequest {
  id              Int                   @id @default(autoincrement())
  employeeId      Int
  reason          String
  lastWorkingDay  DateTime
  status          ClearanceStatus       @default(PENDING)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  checks          ClearanceCheck[]
  employee        Employee         @relation(fields: [employeeId], references: [id])
  payrollTransfer PayrollTransfer?
}

model ClearanceUnit {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  checks      ClearanceCheck[]
}

model ClearanceCheck {
  id              Int              @id @default(autoincrement())
  clearanceId     Int
  unitId          Int
  status          ClearanceStatus  @default(PENDING)
  approverId      Int?
  approvedAt      DateTime?
  comment         String?
  clearance       ClearanceRequest @relation(fields: [clearanceId], references: [id])
  unit            ClearanceUnit    @relation(fields: [unitId], references: [id])

  @@unique([clearanceId, unitId])
}

model PayrollTransfer {
  id            Int              @id @default(autoincrement())
  employeeId    Int
  clearanceId   Int              @unique
  reason        String
  effectiveDate DateTime
  status        String
  createdBy     Int
  createdAt     DateTime         @default(now())
  clearance     ClearanceRequest @relation(fields: [clearanceId], references: [id])
  employee      Employee         @relation(fields: [employeeId], references: [id])
}

model JobPosting {
  id           Int              @id @default(autoincrement())
  title        String
  description  String
  requirements String
  department   String
  position     String
  deadline     DateTime
  status       JobStatus        @default(OPEN)
  createdBy    Int
  createdAt    DateTime         @default(now())
  applications JobApplication[]
  creator      User             @relation("JobCreator", fields: [createdBy], references: [id])
}

model JobApplication {
  id            Int               @id @default(autoincrement())
  jobPostingId  Int
  employeeId    Int
  coverLetter   String
  cvUrl         String
  status        ApplicationStatus @default(SUBMITTED)
  reviewedBy    Int?
  reviewComment String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  employee      Employee          @relation(fields: [employeeId], references: [id])
  jobPosting    JobPosting        @relation(fields: [jobPostingId], references: [id])

  @@unique([jobPostingId, employeeId])
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int
  type        String
  title       String
  message     String
  relatedId   Int?
  relatedType String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model RefreshToken {
  id          Int      @id @default(autoincrement())
  token       String   @unique
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  replacedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum UserRole {
  ADMIN
  HR_OFFICER
  DEPARTMENT_HEAD
  FINANCE_OFFICER
  RECRUITMENT_COMMITTEE
  EMPLOYEE
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ClearanceStatus {
  PENDING
  APPROVED
  REJECTED
}

enum JobStatus {
  OPEN
  CLOSED
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  REJECTED
}

enum SalaryType {
  MONTHLY
  DAILY
}
