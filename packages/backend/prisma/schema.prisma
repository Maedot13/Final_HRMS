generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Campus {
  id                      Int                 @id @default(autoincrement())
  code                    String              @unique
  name                    String
  description             String?
  isActive                Boolean             @default(true)
  timezone                String?             @default("Africa/Addis_Ababa")
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  employeeIdPrefix        String              @default("BDU")
  employeeNumericLength   Int                 @default(5)
  employeeSequenceCurrent Int                 @default(0)
  isPatternLocked         Boolean             @default(false)
  isClearanceSequential   Boolean             @default(false)
  auditLogs               AuditLog[]
  clearanceRequests       ClearanceRequest[]
  clearanceUnits          ClearanceUnit[]
  departments             Department[]
  employees               Employee[]
  jobPostings             JobPosting[]
  leaveBalances           LeaveBalance[]
  leaveRequests           LeaveRequest[]
  notifications           Notification[]
  sabbaticalRequests      SabbaticalRequest[]
  users                   User[]
  clearanceApprovals      ClearanceApproval[]
}

model User {
  id                 Int            @id @default(autoincrement())
  passwordHash       String
  role               UserRole
  employeeId         String         @unique
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  email              String         @unique
  scope              UserScope          @default(CAMPUS)
  campusId           Int?
  mustChangePassword Boolean            @default(false)
  isHeadHR           Boolean            @default(false)
  specialPrivileges  SpecialPrivilege[] @default([])
  clearanceUnitId    Int?
  clearanceUnit      ClearanceUnit? @relation(fields: [clearanceUnitId], references: [id])
  employee           Employee?
  jobPostings        JobPosting[]   @relation("JobCreator")
  notifications      Notification[]
  refreshTokens      RefreshToken[]
  campus             Campus?        @relation(fields: [campusId], references: [id], onDelete: Restrict)
  clearanceApprovals ClearanceApproval[]

  @@index([campusId])
  @@index([clearanceUnitId])
}

model Employee {
  id                 Int                 @id @default(autoincrement())
  userId             Int                 @unique
  employeeId         String              @unique
  name               String
  deptLegacy         String              @map("department")
  position           String
  hireDate           DateTime
  serviceYears       Int                 @default(0)
  contactInfo        Json
  grossSalary        Float               @default(0)
  salaryType         SalaryType          @default(MONTHLY)
  campusId           Int?
  departmentId       Int?
  clearanceRequests  ClearanceRequest[]
  headOf             Department?         @relation("DeptHead")
  campus             Campus?             @relation(fields: [campusId], references: [id], onDelete: Restrict)
  department         Department?         @relation(fields: [departmentId], references: [id])
  user               User                @relation(fields: [userId], references: [id])
  supervisorId       Int?
  supervisor         Employee?           @relation("EmployeeSupervisor", fields: [supervisorId], references: [id])
  subordinates       Employee[]          @relation("EmployeeSupervisor")
  officeLocation     String?
  employmentStatus   EmploymentStatus    @default(ACTIVE)
  contractStartDate  DateTime?
  contractEndDate    DateTime?
  employmentType     EmploymentType      @default(PERMANENT)
  payGrade           String?
  taxInformation     Json?
  jobApplications    JobApplication[]
  leaveBalances      LeaveBalance[]
  leaveRequests      LeaveRequest[]
  payrollTransfers   PayrollTransfer[]
  sabbaticalRequests SabbaticalRequest[]

  @@index([campusId])
}

model LeaveRequest {
  id              Int         @id @default(autoincrement())
  employeeId      Int
  leaveType       LeaveType
  startDate       DateTime
  endDate         DateTime
  days            Int
  reason          String
  attachmentUrl   String?
  status          LeaveStatus @default(PENDING)
  approverId      Int?
  approverComment String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  lastDecisionAt  DateTime?
  resolvedAt      DateTime?
  campusId        Int?
  campus          Campus?     @relation(fields: [campusId], references: [id], onDelete: Restrict)
  employee        Employee    @relation(fields: [employeeId], references: [id])

  @@index([campusId])
  @@index([employeeId, status])
  @@index([status, createdAt])
}

model LeaveBalance {
  id               Int      @id @default(autoincrement())
  employeeId       Int
  year             Int
  annualBalance    Int      @default(0)
  sickBalance      Int      @default(0)
  maternityBalance Int      @default(0)
  paternityBalance Int      @default(0)
  campusId         Int?
  campus           Campus?  @relation(fields: [campusId], references: [id], onDelete: Restrict)
  employee         Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, year])
  @@index([campusId])
}

model SabbaticalRequest {
  id              Int         @id @default(autoincrement())
  employeeId      Int
  purpose         String
  startDate       DateTime
  endDate         DateTime
  durationMonths  Int
  plan            String
  planDocumentUrl String?
  status          LeaveStatus @default(PENDING)
  approverId      Int?
  approverComment String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  lastDecisionAt  DateTime?
  resolvedAt      DateTime?
  campusId        Int?
  campus          Campus?     @relation(fields: [campusId], references: [id], onDelete: Restrict)
  employee        Employee    @relation(fields: [employeeId], references: [id])

  @@index([campusId])
}

model ClearanceRequest {
  id              Int              @id @default(autoincrement())
  employeeId      Int
  reason          String
  lastWorkingDay  DateTime
  status          ClearanceStatus  @default(PENDING)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  campusId        Int?
  initiatedById   Int?
  finalApprovedById Int?
  finalApprovedAt DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  checks          ClearanceCheck[]
  hrApprovals     ClearanceApproval[]
  campus          Campus?          @relation(fields: [campusId], references: [id], onDelete: Restrict)
  employee        Employee         @relation(fields: [employeeId], references: [id])
  payrollTransfer PayrollTransfer?

  @@index([campusId])
}

model ClearanceUnit {
  id                Int              @id @default(autoincrement())
  name              String
  description       String?
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  campusId          Int?
  isSystemGenerated Boolean          @default(false)
  priorityOrder     Int              @default(0)
  users             User[]
  checks            ClearanceCheck[]
  campus            Campus?          @relation(fields: [campusId], references: [id], onDelete: Restrict)

  @@unique([campusId, name])
  @@index([campusId])
}

model ClearanceCheck {
  id          Int              @id @default(autoincrement())
  clearanceId Int
  unitId      Int
  status      ClearanceStatus  @default(PENDING)
  approverId  Int?
  approvedAt  DateTime?
  comment     String?
  clearance   ClearanceRequest @relation(fields: [clearanceId], references: [id])
  unit        ClearanceUnit    @relation(fields: [unitId], references: [id])

  @@unique([clearanceId, unitId])
  @@index([unitId, status])
  @@index([clearanceId, status])
}

model ClearanceApproval {
  id           Int              @id @default(autoincrement())
  clearanceId  Int
  campusId     Int
  approvedById Int
  status       ClearanceStatus  @default(PENDING)
  approvedAt   DateTime?
  notes        String?
  createdAt    DateTime         @default(now())

  clearance    ClearanceRequest @relation(fields: [clearanceId], references: [id], onDelete: Cascade)
  campus       Campus           @relation(fields: [campusId], references: [id], onDelete: Restrict)
  approvedBy   User             @relation(fields: [approvedById], references: [id])

  @@unique([clearanceId, campusId])
  @@index([clearanceId])
  @@index([campusId])
}

model PayrollTransfer {
  id            Int              @id @default(autoincrement())
  employeeId    Int
  clearanceId   Int              @unique
  reason        String
  effectiveDate DateTime
  status        String
  createdBy     Int
  createdAt     DateTime         @default(now())
  clearance     ClearanceRequest @relation(fields: [clearanceId], references: [id])
  employee      Employee         @relation(fields: [employeeId], references: [id])
}

model JobPosting {
  id           Int              @id @default(autoincrement())
  title        String
  description  String
  requirements String
  deptLegacy   String           @map("department")
  position     String
  deadline     DateTime
  status       JobStatus        @default(OPEN)
  createdBy    Int
  createdAt    DateTime         @default(now())
  campusId     Int?
  applications JobApplication[]
  campus       Campus?          @relation(fields: [campusId], references: [id], onDelete: Restrict)
  creator      User             @relation("JobCreator", fields: [createdBy], references: [id])

  @@index([campusId])
}

model JobApplication {
  id            Int               @id @default(autoincrement())
  jobPostingId  Int
  employeeId    Int
  coverLetter   String
  cvUrl         String
  status        ApplicationStatus @default(SUBMITTED)
  reviewedBy    Int?
  reviewComment String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  employee      Employee          @relation(fields: [employeeId], references: [id])
  jobPosting    JobPosting        @relation(fields: [jobPostingId], references: [id])

  @@unique([jobPostingId, employeeId])
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int
  type        String
  title       String
  message     String
  relatedId   Int?
  relatedType String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  campusId    Int?
  campus      Campus?  @relation(fields: [campusId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([campusId])
}

model RefreshToken {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  userId     Int
  expiresAt  DateTime
  revoked    Boolean  @default(false)
  replacedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, revoked])
  @@index([expiresAt])
}

model AuditLog {
  id         Int         @id @default(autoincrement())
  userId     Int?
  action     AuditAction
  entityType String
  entityId   Int?
  changes    Json?
  status     AuditStatus @default(SUCCESS)
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  timestamp  DateTime    @default(now())
  campusId   Int?
  campus     Campus?     @relation(fields: [campusId], references: [id])

  @@index([campusId, timestamp])
  @@index([userId, timestamp])
  @@index([action, timestamp])
  @@index([entityType, entityId])
}

model Department {
  id             Int        @id @default(autoincrement())
  campusId       Int
  name           String
  headEmployeeId Int?       @unique
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  campus         Campus     @relation(fields: [campusId], references: [id])
  head           Employee?  @relation("DeptHead", fields: [headEmployeeId], references: [id])
  employees      Employee[]

  @@unique([campusId, name])
  @@index([campusId])
}

enum UserScope {
  CAMPUS
  UNIVERSITY
}

enum AuditStatus {
  SUCCESS
  FAILURE
  DENIED
}

enum AuditAction {
  USER_LOGIN
  USER_LOGOUT
  USER_REGISTER
  LEAVE_REQUEST_CREATE
  LEAVE_REQUEST_APPROVE
  LEAVE_REQUEST_REJECT
  CLEARANCE_INITIATE
  CLEARANCE_APPROVE
  CLEARANCE_REJECT
  SABBATICAL_REQUEST_CREATE
  SABBATICAL_APPROVE
  SABBATICAL_REJECT
  EMPLOYEE_CREATE
  EMPLOYEE_UPDATE
  PAYROLL_TRANSFER_CREATE
  USER_ROLE_UPDATE
  USER_STATUS_TOGGLE
  AUDIT_LOG_ACCESSED
  AUDIT_LOG_EXPORTED
  CAMPUS_CREATED
  CAMPUS_ACTIVATED
  CAMPUS_SUSPENDED
  DEPARTMENT_CREATED
  DEPARTMENT_HEAD_CHANGED
}
enum SpecialPrivilege {
  DEAN
  DIRECTOR
  UNIVERSITY_PRESIDENT
  VICE_PRESIDENT
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  HR_OFFICER
  DEPARTMENT_HEAD
  FINANCE_OFFICER
  RECRUITMENT_COMMITTEE
  CLEARANCE_BODY
  EMPLOYEE
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ClearanceStatus {
  PENDING
  APPROVED
  REJECTED
  IN_PROGRESS
  BODY_APPROVAL_PENDING
  BODY_APPROVED
  HR_APPROVAL_PENDING
  HR_APPROVED
  FINAL_APPROVED
  COMPLETED
}

enum JobStatus {
  OPEN
  CLOSED
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  REJECTED
}

enum SalaryType {
  MONTHLY
  DAILY
}

enum EmploymentStatus {
  ACTIVE
  SUSPENDED
  TRANSFERRED
}

enum EmploymentType {
  PERMANENT
  CONTRACT
}
