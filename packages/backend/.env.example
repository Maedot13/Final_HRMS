# Application Server Environment
NODE_ENV=development
PORT=3000

# Database Configuration (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hrms_db?schema=public"

# Redis Configuration (For Caching, Rate Limiting, and BullMQ)
REDIS_URL="redis://localhost:6379"

# Security Configurations
# Generate secure random keys for production! (e.g., node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET="your_development_jwt_secret_key_here"
JWT_EXPIRES_IN="1h"

JWT_REFRESH_SECRET="your_development_jwt_refresh_secret_key_here"
JWT_REFRESH_EXPIRES_IN="7d"

# Internal/CORS Context
CORS_ORIGIN="http://localhost:5173"

# Email Configuration (SMTP)
EMAIL_HOST="smtp.example.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@example.com"
EMAIL_PASS="your-email-password"
EMAIL_FROM="HRMS System <noreply@hrms.university.edu>"
