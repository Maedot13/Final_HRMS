# Environment Variables Example

# Database
DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"

# Server
PORT=5000
NODE_ENV="development"

# CORS
CORS_ORIGIN="http://localhost:5173"

# JWT Secrets
# CRITICAL: Generate secure secrets using: node scripts/generate-secrets.js
# NEVER commit actual secrets to version control!
JWT_SECRET="<GENERATE_SECURE_SECRET_HERE>"
JWT_EXPIRES_IN="1h"

# JWT Refresh Secrets
JWT_REFRESH_SECRET="<GENERATE_DIFFERENT_SECURE_SECRET_HERE>"
JWT_REFRESH_EXPIRES_IN="7d"

# Password Hashing
BCRYPT_SALT_ROUNDS="12"

# Redis (for token blacklist and caching)
REDIS_URL="redis://localhost:6379"

# Security Notes:
# 1. Generate cryptographically secure secrets (minimum 64 bytes)
# 2. Use different secrets for JWT and JWT_REFRESH
# 3. Never commit .env file to version control
# 4. Rotate secrets regularly in production
# 5. Use secret management services (AWS Secrets Manager, HashiCorp Vault) in production
# 6. Install and run Redis locally: brew install redis (Mac) or apt-get install redis (Linux)
